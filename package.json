{
  "name": "mews-free-trial",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && rm -rf .next && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "migrate:deploy": "node scripts/migrate-deploy.js",
