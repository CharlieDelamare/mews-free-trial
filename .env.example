# Database Configuration (Prisma Postgres)
# Pooled connection (used by application at runtime)
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=your_api_key_here
# Direct connection (used by Prisma migrations)
DATABASE_DIRECT_URL=postgresql://user:password@host:5432/database?sslmode=require

# Mews API Configuration
MEWS_CLIENT_TOKEN=your_client_token_here
MEWS_ACCESS_TOKEN=your_access_token_here
MEWS_SAMPLE_TOKEN=your_sample_token_here
MEWS_API_URL=https://api.mews-demo.com

# Zapier Webhook Configuration
# Used for all notifications (Slack, CRM, etc.)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your_hook_id/

# Webhook Endpoint for Receiving Access Tokens
# Your webhook URL will be: https://your-domain.vercel.app/api/webhook/access-token
