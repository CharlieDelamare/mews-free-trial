# Database Configuration (Prisma Postgres)
# Accelerate proxy URL (used by application at runtime)
mews_free_trial_PRISMA_DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=your_api_key_here
# Direct connection (used by Prisma migrations)
mews_free_trial_POSTGRES_URL=postgresql://user:password@db.prisma.io:5432/postgres?sslmode=require

# Mews API Configuration
MEWS_CLIENT_TOKEN=your_client_token_here
MEWS_ACCESS_TOKEN=your_access_token_here
MEWS_SAMPLE_TOKEN=your_sample_token_here
MEWS_API_URL=https://api.mews-demo.com

# Slack Workflow Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/triggers/your_trigger_id/

# Webhook Endpoint for Receiving Access Tokens
# Your webhook URL will be: https://mews-free-trial.vercel.app/api/webhook/access-token

# Vostio door management enterprise ID
VOSTIO_ENTERPRISE_ID=
NEXT_PUBLIC_VOSTIO_ENTERPRISE_ID=

# NextAuth — required for authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                    # generate with: openssl rand -base64 32
GOOGLE_CLIENT_ID=                   # from Google Cloud Console OAuth 2.0 client
GOOGLE_CLIENT_SECRET=               # from Google Cloud Console OAuth 2.0 client
