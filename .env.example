# Mews Demo API Configuration
# This is the sample token from your Mews Demo environment for creating trial properties
MEWS_SAMPLE_TOKEN=your_mews_demo_sample_token_here

# Slack API Configuration for notifications
# Create a Slack App at https://api.slack.com/apps and add a Bot Token with chat:write scope
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# Channel ID where notifications will be posted (find this in Slack channel settings)
SLACK_CHANNEL_ID=C0123456789
